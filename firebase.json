{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  }
  ,
  "emulators": {
    "functions": { "port": 5005 },
    "firestore": { "port": 8081 },
    "database": { "port": 9001 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
